# 应用
APP_NAME=Self-Agent API
APP_ENV=dev
API_PORT=8000

# 数据库（本地 docker-compose 默认值）
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/self_agent

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
EMBEDDING_MODEL=models/gemini-embedding-001
LLM_MODEL=models/gemini-2.5-flash
EMBEDDING_DIM=3072

# 可选：跨境代理（本地开发如需代理访问 Gemini 填写）
PROXY_URL=

# CORS 允许来源，逗号分隔。生产必须显式配置，默认仅本地前端。
# 例：CORS_ORIGINS=https://self-agent-web.onrender.com,https://example.com
CORS_ORIGINS=http://localhost:5173
